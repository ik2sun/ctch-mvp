# Supabase 프로젝트 설정 > API 에서 복사 (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# 배포 시 실제 도메인 (로컬은 그대로 두세요)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Apify (브랜드 분석 — 인스타그램 프로필 수집). 없으면 샘플 데이터로 대체됩니다.
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 회원 승인 시스템 — 이 이메일로 가입하면 자동으로 최고관리자(superadmin)로 승인됩니다.
SUPERADMIN_EMAIL=owner@nmg.co.kr

# Supabase 프로젝트 설정 > API > service_role 키. 관리자 승인/역할변경에 필요 (RLS 우회).
# 절대 클라이언트에 노출되지 않아야 하며, 서버 전용 코드에서만 사용됩니다.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
